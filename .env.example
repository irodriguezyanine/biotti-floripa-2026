# Cloudinary (server-side only)
# Opcion recomendada: usar el string completo del dashboard (evita cloud_name mismatch)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Opcion alternativa: variables separadas
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: folder destino en Cloudinary
# CLOUDINARY_UPLOAD_FOLDER=biotti-floripa-2026/gallery
